{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "$id": "https://ploinky.local/llm-runtime/launcher-describe.schema.json",
    "title": "Launcher describe output",
    "type": "object",
    "additionalProperties": false,
    "required": ["schemaVersion", "id", "engine", "supportedAccelerators"],
    "properties": {
        "schemaVersion": { "type": "integer", "const": 1 },
        "id": { "type": "string", "pattern": "^[a-zA-Z0-9](?:[a-zA-Z0-9_-]|[.](?=[a-zA-Z0-9_-])){0,127}$" },
        "engine": { "type": "string", "minLength": 1, "maxLength": 64 },
        "modelRepo": { "type": "string", "maxLength": 256 },
        "modelFiles": { "type": "array", "items": { "type": "string", "maxLength": 256 } },
        "supportedAccelerators": {
            "type": "array",
            "minItems": 1,
            "items": { "enum": ["cpu", "nvidia-cuda", "amd-rocm", "vulkan", "intel-openvino"] }
        },
        "supportedPlatforms": {
            "type": "array",
            "items": { "enum": ["linux/amd64", "linux/arm64"] }
        },
        "capabilities": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
                "chat": { "type": "boolean" },
                "embeddings": { "type": "boolean" },
                "rerank": { "type": "boolean" }
            }
        }
    }
}
