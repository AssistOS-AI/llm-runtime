{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "$id": "https://ploinky.local/llm-runtime/launch-config.schema.json",
    "title": "Launch configuration (input to launcher prepare/start)",
    "type": "object",
    "additionalProperties": false,
    "required": ["instanceId", "launcher"],
    "properties": {
        "instanceId": { "type": "string", "pattern": "^[a-z0-9][a-z0-9_-]{0,63}$" },
        "launcher": { "type": "string", "pattern": "^[a-zA-Z0-9._-]+$" },
        "parameters": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
                "temperature": { "type": "number", "minimum": 0, "maximum": 2 },
                "topP": { "type": "number", "minimum": 0, "maximum": 1 },
                "maxTokens": { "type": "integer", "minimum": 1, "maximum": 1048576 },
                "contextLength": { "type": "integer", "minimum": 1, "maximum": 1048576 }
            }
        }
    }
}
